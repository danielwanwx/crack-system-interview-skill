{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://danielwanwx.github.io/crack-system-interview-skill/schema/interview-case.json",
  "title": "Interview Case",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "title",
    "type",
    "level",
    "prompt",
    "requirements",
    "estimates",
    "api",
    "entities",
    "architecture",
    "deep_dives",
    "interviewer_followups",
    "reference_answer",
    "rubric",
    "repair_tasks",
    "sources",
    "related_algorithms"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "title": {"type": "string"},
    "type": {"enum": ["project", "concept", "mock"]},
    "level": {"enum": ["mid", "senior", "staff"]},
    "prompt": {"type": "object", "required": ["interviewer", "baseline"]},
    "requirements": {"type": "object", "required": ["functional", "non_functional", "out_of_scope"]},
    "estimates": {"type": "array", "minItems": 1},
    "api": {"type": "array", "minItems": 1},
    "entities": {"type": "array", "minItems": 1},
    "architecture": {"type": "object", "required": ["components", "flows"]},
    "deep_dives": {"type": "array", "minItems": 2},
    "interviewer_followups": {"type": "array", "minItems": 4},
    "reference_answer": {"type": "array", "minItems": 5},
    "rubric": {"type": "object", "required": ["passing_score", "dimensions", "critical_misses"]},
    "repair_tasks": {"type": "array", "minItems": 1},
    "sources": {"type": "array", "minItems": 1},
    "related_algorithms": {"type": "object", "required": ["tag", "required"]}
  },
  "additionalProperties": false
}
